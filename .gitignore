# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
venv/
.venv/
env/
.env

# Pacemaker databases — never commit real DBs
*.db
*.db-shm
*.db-wal

# Sync state — user-specific, generated at runtime
rb_pacemaker_sync_state.json

# PyInstaller / packaging — the top-level build spec is tracked (it has
# hand-tuned hiddenimports/icon config), stray/auto-generated ones are not
*.spec
!/rekordbox_pacemaker_sync.spec
*.manifest

# Inno Setup installer output
*.exe

# IDE / OS
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# Logs
*.log

# Test/type-checker caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
